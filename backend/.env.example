FLASK_ENV=development
SECRET_KEY=your_random_32_character_secret_key_here
JWT_SECRET_KEY=your_random_32_character_jwt_secret_key_here
JWT_ACCESS_TOKEN_EXPIRES=3600
MONGO_URI=mongodb://localhost:27017/promesapay
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key_here
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password
SMTP_FROM_EMAIL=noreply@promesapay.com
SMTP_FROM_NAME=PromesaPay
REDIS_URL=redis://localhost:6379/0
LOG_LEVEL=INFO
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
RATELIMIT_STORAGE_URL=memory://
RATELIMIT_STRATEGY=fixed-window
CORS_ORIGINS=http://localhost:5173
